{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "api-gateway/Dockerfile.railway",
    "watchPatterns": [
      "api-gateway/**",
      "teamsync-common/**",
      "pom.xml"
    ]
  },
  "deploy": {
    "numReplicas": 1,
    "healthcheckPath": "/actuator/health",
    "healthcheckTimeout": 300,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
