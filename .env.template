# =============================================================================
# TeamSync Backend Environment Variables Template
# =============================================================================
# Copy this file to .env and fill in the values.
# For production, all secrets should be sourced from Vault via Config Server.
#
# To get production values from Vault:
#   export VAULT_ADDR=https://vault-production-xxxx.up.railway.app
#   export VAULT_TOKEN=<your-vault-token>
#   vault kv get secret/platform/<path>
# =============================================================================

# =============================================================================
# INFRASTRUCTURE
# =============================================================================

# MongoDB
# Vault path: secret/platform/mongodb
MONGODB_URI=

# Redis
# Vault path: secret/platform/redis
REDIS_URL=
REDIS_HOST=
REDIS_PORT=6379

# Kafka
# Vault path: secret/platform/kafka
KAFKA_BOOTSTRAP_SERVERS=

# Elasticsearch
# Vault path: secret/platform/elasticsearch
ELASTICSEARCH_URI=

# =============================================================================
# STORAGE
# =============================================================================

# MinIO/S3
# Vault path: secret/platform/minio
MINIO_ENDPOINT=
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=

# Storage Provider (minio, s3, gcs)
STORAGE_PROVIDER=minio

# =============================================================================
# SECURITY
# =============================================================================

# JWT
# Vault path: secret/platform/jwt
JWT_SECRET=
JWT_ISSUER=
JWT_AUDIENCE=

# Download Token Secret
# Vault path: secret/platform/teamsync
DOWNLOAD_TOKEN_SECRET=

# WOPI Token Secret
# Vault path: secret/platform/wopi
WOPI_TOKEN_SECRET=

# =============================================================================
# ZITADEL (Identity Provider)
# =============================================================================

# Vault path: secret/platform/zitadel
ZITADEL_ISSUER=
ZITADEL_INTERNAL_URL=
ZITADEL_PROJECT_ID=
ZITADEL_CLIENT_ID=
ZITADEL_ADMIN_USERNAME=
ZITADEL_ADMIN_PASSWORD=

# =============================================================================
# THIRD-PARTY SERVICES
# =============================================================================

# SendGrid
# Vault path: secret/platform/sendgrid
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
SENDGRID_FROM_NAME=

# OpenAI
# Vault path: secret/platform/openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4

# Anthropic
# Vault path: secret/platform/anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-sonnet

# Firebase (for push notifications)
# Vault path: secret/platform/firebase
FIREBASE_PROJECT_ID=

# =============================================================================
# CONFIG SERVER
# =============================================================================

# Vault path: secret/platform/config-server
CONFIG_SERVER_URI=http://config-server:8888
CONFIG_SERVER_USER=
CONFIG_SERVER_PASSWORD=

# Vault Token
VAULT_TOKEN=
