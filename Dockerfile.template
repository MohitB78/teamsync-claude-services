# Multi-stage Dockerfile template for TeamSync services
# Copy this file to each service directory as Dockerfile

# Build stage
FROM eclipse-temurin:21-jdk-alpine AS builder

WORKDIR /app

# Copy Maven wrapper and POM files
COPY ../pom.xml ../pom.xml
COPY ../teamsync-common/pom.xml ../teamsync-common/pom.xml
COPY pom.xml .

# Download dependencies (cached layer)
RUN --mount=type=cache,target=/root/.m2 \
    cd .. && ./mvnw dependency:go-offline -pl teamsync-common,${SERVICE_NAME}

# Copy source code
COPY ../teamsync-common/src ../teamsync-common/src
COPY src ./src

# Build the application
# Use maven.test.skip=true to skip both test compilation and execution
RUN --mount=type=cache,target=/root/.m2 \
    cd .. && ./mvnw clean package -pl teamsync-common,${SERVICE_NAME} -Dmaven.test.skip=true

# Runtime stage
FROM eclipse-temurin:21-jre-alpine

WORKDIR /app

# Add non-root user
RUN addgroup -S teamsync && adduser -S teamsync -G teamsync
USER teamsync

# Copy the built JAR
COPY --from=builder /app/target/*.jar app.jar

# Health check
HEALTHCHECK --interval=30s --timeout=10s --retries=3 \
    CMD wget --no-verbose --tries=1 --spider http://localhost:${SERVER_PORT}/actuator/health || exit 1

# Expose port
EXPOSE ${SERVER_PORT}

# Run the application
ENTRYPOINT ["java", "-XX:+UseG1GC", "-XX:MaxRAMPercentage=75.0", "-jar", "app.jar"]
